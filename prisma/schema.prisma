datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum Country {
  INDIA
  AMERICA
}

enum OrderStatus {
  PENDING
  PLACED
  CANCELLED
}

enum PaymentType {
  CARD
  UPI
  WALLET
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           Role
  country        Country?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orders         Order[]
  paymentMethods PaymentMethod[]
}

model Restaurant {
  id          String     @id @default(uuid())
  name        String
  description String
  imageUrl    String
  country     Country
  isActive    Boolean    @default(true)
  menuItems   MenuItem[]
  orders      Order[]
}

model MenuItem {
  id           String      @id @default(uuid())
  name         String
  description  String
  price        Float
  imageUrl     String
  isAvailable  Boolean     @default(true)
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
}

model Order {
  id           String      @id @default(uuid())
  status       OrderStatus @default(PENDING)
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  totalAmount  Float       @default(0.0)
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  quantity   Int
  unitPrice  Float
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id        String      @id @default(uuid())
  type      PaymentType
  label     String
  isDefault Boolean     @default(false)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}
